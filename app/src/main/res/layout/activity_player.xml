<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:keepScreenOn="true"
    android:fitsSystemWindows="false">

    <org.videolan.libvlc.util.VLCVideoLayout
        android:id="@+id/vlc_video_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="false"/>

    <!-- Night mode overlay -->
    <View
        android:id="@+id/night_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#88000000"
        android:visibility="gone"/>

    <!-- Controls overlay -->
    <LinearLayout
        android:id="@+id/controls_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#55000000">

        <!-- Top bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="4dp">

            <ImageButton android:id="@+id/btn_back"
                android:layout_width="40dp" android:layout_height="40dp"
                android:background="?selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_media_previous"
                android:tint="#FFFFFF" android:contentDescription="back"/>

            <TextView android:id="@+id/tv_title"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:paddingHorizontal="6dp"
                android:textColor="#FFFFFF" android:textSize="13sp"
                android:textStyle="bold" android:ellipsize="end" android:maxLines="1"/>

            <TextView android:id="@+id/tv_speed"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="1.0x" android:textColor="#FFFFFF" android:textSize="11sp"/>

            <ImageButton android:id="@+id/btn_speed"
                android:layout_width="32dp" android:layout_height="32dp"
                android:background="?selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_recent_history"
                android:tint="#FFFFFF" android:contentDescription="speed"/>

            <ImageButton android:id="@+id/btn_eq"
                android:layout_width="32dp" android:layout_height="32dp"
                android:background="?selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_manage"
                android:tint="#FFFFFF" android:contentDescription="eq"/>

            <ImageButton android:id="@+id/btn_filter"
                android:layout_width="32dp" android:layout_height="32dp"
                android:background="?selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_camera"
                android:tint="#E94560" android:contentDescription="filter"/>

            <ImageButton android:id="@+id/btn_night"
                android:layout_width="32dp" android:layout_height="32dp"
                android:background="?selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_day"
                android:tint="#FFD700" android:contentDescription="night"/>

            <ImageButton android:id="@+id/btn_bookmark"
                android:layout_width="32dp" android:layout_height="32dp"
                android:background="?selectableItemBackgroundBorderless"
                android:src="@android:drawable/btn_star_big_off"
                android:tint="#FFFFFF" android:contentDescription="bookmark"/>

            <ImageButton android:id="@+id/btn_pip"
                android:layout_width="32dp" android:layout_height="32dp"
                android:background="?selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_slideshow"
                android:tint="#FFFFFF" android:contentDescription="pip"/>

            <ImageButton android:id="@+id/btn_aspect"
                android:layout_width="32dp" android:layout_height="32dp"
                android:background="?selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_zoom"
                android:tint="#FFFFFF" android:contentDescription="aspect"/>

            <ImageButton android:id="@+id/btn_lock"
                android:layout_width="32dp" android:layout_height="32dp"
                android:background="?selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_lock_lock"
                android:tint="#FFFFFF" android:contentDescription="lock"/>

            <ImageButton android:id="@+id/btn_translate"
                android:layout_width="32dp" android:layout_height="32dp"
                android:background="?selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_edit"
                android:tint="#E94560" android:contentDescription="translate"/>
        </LinearLayout>

        <!-- Center controls -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageButton android:id="@+id/btn_prev"
                android:layout_width="44dp" android:layout_height="44dp"
                android:background="?selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_media_previous"
                android:tint="#CCFFFFFF" android:contentDescription="prev"/>

            <ImageButton android:id="@+id/btn_rewind"
                android:layout_width="50dp" android:layout_height="50dp"
                android:layout_marginHorizontal="8dp"
                android:background="?selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_media_rew"
                android:tint="#FFFFFF" android:contentDescription="rewind"/>

            <ImageButton android:id="@+id/btn_play_pause"
                android:layout_width="72dp" android:layout_height="72dp"
                android:layout_marginHorizontal="12dp"
                android:background="@drawable/circle_button_bg"
                android:src="@android:drawable/ic_media_pause"
                android:tint="#FFFFFF" android:contentDescription="play"/>

            <ImageButton android:id="@+id/btn_forward"
                android:layout_width="50dp" android:layout_height="50dp"
                android:layout_marginHorizontal="8dp"
                android:background="?selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_media_ff"
                android:tint="#FFFFFF" android:contentDescription="forward"/>

            <ImageButton android:id="@+id/btn_next"
                android:layout_width="44dp" android:layout_height="44dp"
                android:background="?selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_media_next"
                android:tint="#CCFFFFFF" android:contentDescription="next"/>
        </LinearLayout>

        <!-- Bottom bar: seekbar + playlist controls -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="12dp"
            android:paddingBottom="8dp">

            <!-- Shuffle + Repeat + Queue -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="4dp">

                <ImageButton android:id="@+id/btn_shuffle"
                    android:layout_width="32dp" android:layout_height="32dp"
                    android:background="?selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_menu_sort_by_size"
                    android:tint="#AAFFFFFF" android:contentDescription="shuffle"
                    android:alpha="0.5"/>

                <ImageButton android:id="@+id/btn_repeat"
                    android:layout_width="32dp" android:layout_height="32dp"
                    android:layout_marginStart="8dp"
                    android:background="?selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_menu_rotate"
                    android:tint="#AAFFFFFF" android:contentDescription="repeat"
                    android:alpha="0.4"/>

                <View android:layout_width="0dp" android:layout_height="0dp"
                    android:layout_weight="1"/>

                <ImageButton android:id="@+id/btn_queue"
                    android:layout_width="32dp" android:layout_height="32dp"
                    android:background="?selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_menu_agenda"
                    android:tint="#AAFFFFFF" android:contentDescription="queue"/>
            </LinearLayout>

            <SeekBar android:id="@+id/seekBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:progressTint="#E94560"
                android:thumbTint="#E94560"/>

            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content" android:orientation="horizontal">
                <TextView android:id="@+id/tv_current"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="00:00" android:textColor="#FFFFFF" android:textSize="12sp"/>
                <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>
                <TextView android:id="@+id/tv_total"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="00:00" android:textColor="#FFFFFF" android:textSize="12sp"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Lock overlay -->
    <FrameLayout
        android:id="@+id/lock_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end|center_vertical"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="16dp">
            <ImageButton android:id="@+id/btn_unlock"
                android:layout_width="48dp" android:layout_height="48dp"
                android:background="@drawable/circle_button_bg"
                android:src="@android:drawable/ic_lock_lock"
                android:tint="#FFFFFF" android:contentDescription="unlock"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Mo khoa" android:textColor="#AAFFFFFF"
                android:textSize="10sp" android:layout_marginTop="4dp"/>
        </LinearLayout>
    </FrameLayout>

</FrameLayout>
